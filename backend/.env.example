# -----------------------------------------------------------------------------
# Backend database connection
# Used by the Rust backend.
#
# Local backend with `cargo run`:
#   Use host `localhost`:
#   DATABASE_URL=postgres://fitpulse:fitpulse_dev_password@localhost:5432/fitpulse
#
# Docker Compose (if you run it from here):
#   Use host `db`, because `db` is the PostgreSQL service name in docker-compose.yml.
#   DATABASE_URL=postgres://fitpulse:fitpulse_dev_password@db:5432/fitpulse
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://fitpulse:fitpulse_dev_password@localhost:5432/fitpulse

# -----------------------------------------------------------------------------
# Rust backend
# -----------------------------------------------------------------------------
APP_PORT=3000

# Development-only secret.
# Replace this with a long random value in production.
JWT_SECRET=replace-this-with-a-long-random-secret-for-production

# For local development, `*` is okay.
# In production, use your real frontend origin instead.
CORS_ORIGIN=*
