# Copy this file to `.env` in the project root before starting the app.
#
# macOS / Linux:
#   cp .env.example .env
#
# Windows PowerShell:
#   Copy-Item .env.example .env
#
# Never commit your real `.env` file. It may contain secrets.

# -----------------------------------------------------------------------------
# PostgreSQL database container
# Used by the `db` service in docker-compose.yml.
# -----------------------------------------------------------------------------
POSTGRES_USER=fitpulse
POSTGRES_PASSWORD=fitpulse_dev_password
POSTGRES_DB=fitpulse

# -----------------------------------------------------------------------------
# Rust backend
# -----------------------------------------------------------------------------
APP_PORT=4000

# Development-only secret.
# Replace this with a long random value in production.
JWT_SECRET=replace-this-with-a-long-random-secret-for-production

# -----------------------------------------------------------------------------
# CORS Origin
# -----------------------------------------------------------------------------
# Local development:
CORS_ORIGIN=*

# Production browser frontend example:
# CORS_ORIGIN=https://app.example.com

# Trust X-Forwarded-For only when requests come from these proxy IPs.
# Leave disabled unless the backend is behind a reverse proxy you control.
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_IPS=127.0.0.1,::1

# -----------------------------------------------------------------------------
# Expo / React Native frontend
#
# Development Android Emulator:
#   http://10.0.2.2:3000/api
#
# iOS Simulator or web browser on the same machine:
#   http://localhost:3000/api
#
# Physical phone on the same Wi-Fi:
#   http://YOUR_COMPUTER_IP:3000/api
#   Example: http://192.168.178.25:3000/api
#
# Production with Nginx + HTTPS:
#   https://api.example.com/api
# -----------------------------------------------------------------------------
# -----------------------------------------------------------------------------
# AI Configuration (Moonshot / Kimi)
# -----------------------------------------------------------------------------
MOONSHOT_API_KEY=your-moonshot-api-key-here
MOONSHOT_API_BASE=https://api.moonshot.cn/v1
MOONSHOT_MODEL=moonshot-v1-8k
